{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".opencode/instructions/vibiz-sandbox.md"],
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "snapshot": false,
  "lsp": true,
  "formatter": true,
  "provider": {
    "anthropic": {
      "options": {
        "setCacheKey": true,
        "timeout": 600000,
        "chunkTimeout": 30000
      },
      "models": {
        "claude-sonnet-4-5": {
          "options": {
            "thinking": { "type": "disabled" }
          }
        },
        "claude-haiku-4-5": {
          "options": {
            "thinking": { "type": "disabled" }
          }
        }
      }
    }
  },
  "tools": {
    "webfetch": false,
    "websearch": false
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".next/**",
      "out/**",
      "dist/**",
      ".git/**",
      "*.log"
    ]
  }
}
