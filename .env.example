# Auth — set TURSO_DATABASE_URL (or DATABASE_URL for back-compat) to enable sign-in
# Local dev: run `turso dev` and use libsql://localhost:8080 (file:// is not supported by the libsql Kysely dialect)
# Production: set automatically by vibiz on deploy (Turso)
# Leave empty for landing-page-only mode (no auth)
TURSO_DATABASE_URL=libsql://localhost:8080
TURSO_AUTH_TOKEN=
BETTER_AUTH_SECRET=change-me-to-a-random-string
# BETTER_AUTH_URL: only set if you want to override the inferred URL.
# On Vercel: auto-derived from VERCEL_URL.
# Locally: defaults to http://localhost:3100.
# BETTER_AUTH_URL=

# Stripe — NOT NEEDED in the deployed app. Vibiz mints a Stripe Payment Link
# per offer platform-side and seeds the URL into `data/offers.json`. The
# Pricing component renders <a href={offer.paymentLinkUrl}>Buy now</a> and
# Stripe handles checkout on its hosted page. Webhook attribution stays
# platform-side. To change pricing/offers, edit them in the Vibiz dashboard
# then click Republish.

# App URL — only set to override. On Vercel, derived from VERCEL_URL.
# NEXT_PUBLIC_APP_URL=http://localhost:3100

# Sapiom — AI services (chat, image, search, audio)
# Scoped per-deployment key issued by vibiz at deploy time via:
#   sapiom_create_agent → sapiom_create_spending_rule → sapiom_create_transaction_api_key
# Empty = /api/ai/* and the public landing FAQ "Ask AI" widget return 503.
# Never expose to the browser.
SAPIOM_API_KEY=
# Agent name used for per-workspace spend attribution + $5 rolling 30-day cap.
# Vibiz provisioning sets this to `vibiz-<last8 of orgId>`. Defaults to
# "vibiz-saas" if unset, in which case the workspace-level budget cap does
# NOT apply — only leave empty in dev.
# SAPIOM_AGENT_NAME=
# Note: vibiz today also injects SAPIOM_AGENT_ID (the agent's UUID) but the
# chassis only reads SAPIOM_AGENT_NAME. Until that's reconciled in
# `vibiz/lib/services/sandbox/provision-credentials.ts`, deployed apps fall
# through to the default agent name. Tracked under EP-1434.
